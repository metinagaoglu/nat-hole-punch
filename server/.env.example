# UDP Hole Punch Server Configuration

# Server Configuration
SERVER_PORT=3986
SERVER_HOST=0.0.0.0
BUFFER_SIZE=1024

# Client Configuration
CLIENT_TTL=60

# Repository Configuration
# Options: "memory" or "redis"
REPOSITORY_TYPE=memory

# Redis Configuration (only needed if REPOSITORY_TYPE=redis)
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
